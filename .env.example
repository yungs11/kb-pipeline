# 8.kb-pipeline/.env.example — key catalog for docker-compose.yml
# Copy to .env and fill real values. .env is gitignored — NEVER commit it.
# Real secrets stay blank here. Safe non-secret defaults are shown where applicable.

# ---------------------------------------------------------------------------
# OpenRouter — edgequake LLM + facade/parse-svc LLM
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
KBP_OPENAI_API_KEY=          # parse-svc + facade LLM key (OpenRouter or litellm proxy)
KBP_OPENAI_BASE_URL=https://openrouter.ai/api/v1
KBP_LLM_MODEL=qwen/qwen3.5-122b-a10b

# ---------------------------------------------------------------------------
# litellm proxy — BGE-M3 embeddings (edgequake)
# ---------------------------------------------------------------------------
LITELLM_EMBEDDING_API_KEY=
LITELLM_EMBEDDING_BASE_URL=https://litellm.ax-demo.com/v1

# ---------------------------------------------------------------------------
# VL model — document-parser (optional vision-language backend)
# ---------------------------------------------------------------------------
MODEL_API_URL=
MODEL_API_KEY=

# ---------------------------------------------------------------------------
# MinIO — document-parser + parse-svc + facade
# ---------------------------------------------------------------------------
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=document-parser

# ---------------------------------------------------------------------------
# Postgres — edgequake graph DB
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=edgequake_secret

# ---------------------------------------------------------------------------
# adaptive_chunk — all 16 ADAPTIVE_CHUNK_* keys (env_prefix="ADAPTIVE_CHUNK_")
# Do NOT use env_file: in compose — each key is listed explicitly to avoid leaking secrets.
# ---------------------------------------------------------------------------

# OpenRouter API key for adaptive_chunk LLM calls (regex/coref/scoring)
ADAPTIVE_CHUNK_OPENROUTER_API_KEY=

# OpenRouter base URL
ADAPTIVE_CHUNK_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Scoring embedding model (e.g. bge-m3)
ADAPTIVE_CHUNK_SCORING_EMBEDDING_MODEL=bge-m3

# Scoring embedding endpoint — must be reachable FROM INSIDE the container.
# localhost:8899 or localhost:7997 are unreachable in-container.
# Use the remote litellm URL: https://litellm.ax-demo.com/v1
ADAPTIVE_CHUNK_SCORING_EMBEDDING_BASE_URL=https://litellm.ax-demo.com/v1

ADAPTIVE_CHUNK_SCORING_EMBEDDING_API_KEY=

# Per-call HTTP timeout for scoring embedding (seconds). Generous for large document batches.
ADAPTIVE_CHUNK_SCORING_EMBEDDING_TIMEOUT_S=600

# LLM model for regex/evaluation step (OpenRouter)
ADAPTIVE_CHUNK_REGEX_LLM_MODEL=qwen/qwen3.5-122b-a10b

# OCR backend — hard-coded in compose to http://document-parser:8000 (intra-stack DNS).
# DO NOT set this to localhost:18050 — unreachable inside the container.
# This var is listed here for documentation; compose overrides it unconditionally.
ADAPTIVE_CHUNK_OCR_BASE_URL=http://document-parser:8000

# Edgequake base URL — if adaptive_chunk needs to call edgequake, use intra-stack DNS:
# http://edgequake:8081
# The host value (localhost:8899 or localhost:8081) is unreachable in-container.
ADAPTIVE_CHUNK_EDGEQUAKE_BASE_URL=http://edgequake:8081

# Job-level timeout (seconds)
ADAPTIVE_CHUNK_JOB_TIMEOUT_S=1200

# Reranker model (e.g. Qwen3-Reranker-0.6B via litellm)
ADAPTIVE_CHUNK_RERANK_MODEL=Qwen3-Reranker-0.6B

# Reranker endpoint — must be reachable FROM INSIDE the container.
# Use remote litellm URL: https://litellm.ax-demo.com/v1
ADAPTIVE_CHUNK_RERANK_BASE_URL=https://litellm.ax-demo.com/v1

ADAPTIVE_CHUNK_RERANK_API_KEY=

# Coreference LLM model (used for RC scoring)
ADAPTIVE_CHUNK_COREF_LLM_MODEL=qwen/qwen3.5-122b-a10b

# Coreference reasoning toggle: 'off' = disabled (fast), 'on' = enabled (slow)
ADAPTIVE_CHUNK_COREF_REASONING=off
